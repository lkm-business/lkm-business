PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/lkm_business

# JWT
JWT_SECRET=change_this_secret_key_in_production
JWT_EXPIRES_IN=7d

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_app_password
FROM_EMAIL=noreply@lkmbusiness.com
FROM_NAME=LKM_BUSINESS

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# CinetPay (Orange Money / Wave)
CINETPAY_API_KEY=votre_api_key
CINETPAY_SITE_ID=votre_site_id

# Notification WhatsApp (CallMeBot) quand une commande contient des produits numériques
CALLMEBOT_API_KEY=
ADMIN_WHATSAPP_NUMBER=221784358021

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost:3000
